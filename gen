#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"

show_help() {
  cat <<EOF
⚛️  abu — React Boilerplate CLI

Usage:
  abu <command> <n> [options]

Commands:
  component   Create a component in src/show/components/    (alias: c)
  page        Create a page in src/show/pages/              (alias: p)
  locale      Create a locale JSON in all language folders   (alias: l)
  reducer     Create a Redux Toolkit reducer                 (alias: r)

Options:
  --connect       Wrap with Redux connect (index.ts + view.tsx)
  --<scope>       (pages only) Target subfolder, e.g. --public, --session, --admin
                  Defaults to 'shared' if no scope provided

Arguments can be in any order:
  abu c MyButton --connect
  abu --connect c MyButton
  abu MyButton --connect c

EOF
}

COMMAND=""
REMAINING=()

for arg in "$@"; do
  case "$arg" in
    component|c)  COMMAND="component" ;;
    page|p)       COMMAND="page" ;;
    locale|l)     COMMAND="locale" ;;
    reducer|r)    COMMAND="reducer" ;;
    help|--help|-h) show_help; exit 0 ;;
    *) REMAINING+=("$arg") ;;
  esac
done

if [ -z "$COMMAND" ]; then
  show_help
  exit 0
fi

case "$COMMAND" in
  component) "$SCRIPT_DIR/commands/component.sh" "${REMAINING[@]}" ;;
  page)      "$SCRIPT_DIR/commands/page.sh" "${REMAINING[@]}" ;;
  locale)    "$SCRIPT_DIR/commands/locale.sh" "${REMAINING[@]}" ;;
  reducer)   "$SCRIPT_DIR/commands/reducer.sh" "${REMAINING[@]}" ;;
esac
